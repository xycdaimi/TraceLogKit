    { "asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true, "tags": [], "targetBlank": false, "title": "Business Metrics", "type": "link", "url": "/d/tracelogkit_business_metrics" },
    { "asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true, "tags": [], "targetBlank": false, "title": "Traces", "type": "link", "url": "/d/tracelogkit_traces" }
  ],
  "panels": [
    {
      "description": "**流程**：告警 → 按 project 过滤 → 从错误日志找到 task_id → 点击 task_id 跳转 Traces 面板进行链路回溯。\n\n**说明**：日志需为 JSON，包含 `level`/`service`/`task_id`/`trace_id`；`project` 为 Loki label。**Project 任务失败率** = 基于 `event=task.result.get` 日志的 `status` 字段（失败=非 success）；**Service 任务失败率** = 基于报错日志的 `status=failed`。告警按 project 聚合。",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "content": "", "mode": "markdown" },
      "title": "使用说明",
      "type": "text"
    },
    {
      "datasource": { "type": "grafana", "uid": "-- Grafana --" },
      "description": "当前触发的告警，点击告警 description 中的链接进入对应排查面板。",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "id": 2,
      "options": { "maxItems": 30, "sortOrder": 1, "dashboardAlerts": false, "stateFilter": { "firing": true, "normal": false, "noData": false, "error": false, "pending": false } },
      "title": "告警列表（Firing）",
      "type": "alertlist"
    },
    {
      "datasource": { "type": "loki", "uid": "tracelogkit-loki" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [{ "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": false } }] }] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 13 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "sum by (project) (count_over_time({project=~\"${project:.+}\"} | json | level=~\"(?i)error\" [5m]))", "legendFormat": "{{project}}", "refId": "A" }],
      "title": "错误日志量（5m）- 按 project",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "tracelogkit-loki" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [{ "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": false } }] }] },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 13 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "single", "sort": "none" } },
      "targets": [{ "expr": "topk(10, sum by (service) (count_over_time({project=~\"$project\"} | json | level=\"error\" | label_format service=\"{{.service}}\" [5m])))", "legendFormat": "{{service}}", "refId": "A" }],
      "title": "Top services by error logs (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "tracelogkit-loki" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [{ "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": false } }] }] },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 23 },
      "description": "失败任务数/任务数（5m）。基于报错日志：任务数 = 去重 task_id 数；失败 = 该 task_id 下存在 status=failed 的日志。按 service 需 label_format 提取 task_id、service。",
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "100 * (count by (project, service) (count_over_time({project=~\"$project\"} | json | label_format task_id=\"{{.task_id}}\" | label_format service=\"{{.service}}\" | task_id=~\".+\" | status=~\"(?i)failed\" [5m])) / count by (project, service) (count_over_time({project=~\"$project\"} | json | label_format task_id=\"{{.task_id}}\" | label_format service=\"{{.service}}\" | task_id=~\".+\" [5m])))", "legendFormat": "{{service}}", "refId": "A" }],
      "title": "任务失败率 (%) - 按 service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "tracelogkit-loki" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [{ "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "custom.hideFrom", "value": { "legend": true, "tooltip": false, "viz": false } }] }] },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 23 },
      "description": "失败任务数/任务数（5m）。基于 event=task.result.get 日志的 status 字段；失败 = status 非 success（如 FAILED、failed，大小写不敏感）。",
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "100 * (count by (project) (count_over_time({project=~\"$project\"} | json | event=\"task.result.get\" | task_id=~\".+\" | status=~\"(?i)failed\" [5m])) / count by (project) (count_over_time({project=~\"$project\"} | json | event=\"task.result.get\" | task_id=~\".+\" [5m])))", "legendFormat": "{{project}}", "refId": "A" }],
      "title": "任务失败率 (%) - 按 project",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "tracelogkit-loki" },
      "description": "点击 task_id 跳转 Traces 面板查看该任务所有 trace（首次+重试）；点击 trace_id 跳转 Tempo 查看单次执行。",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 33 },
      "id": 7,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": true, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{ "expr": "{project=~\"${project:.+}\"} | json | level=~\"(?i)error\" | service=~\"$service\"", "refId": "A" }],
      "title": "最近错误日志（点击 task_id → Traces）",
      "type": "logs"
    },
    {
      "description": "--- 按 task_id / trace_id / request_id 精确查日志 ---",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 47 },
      "id": 8,
      "options": { "content": "", "mode": "markdown" },
      "title": "日志 Drilldown",
      "type": "text"
    },
    {
      "datasource": { "type": "loki", "uid": "tracelogkit-loki" },
      "description": "输入 task_id 后点击「Traces」链接查看该任务所有 trace 的链路可视化。",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 51 },
      "id": 9,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": true, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{ "expr": "{project=~\"$project\"} | json | task_id=\"$task_id\"", "refId": "A" }],
      "title": "按 task_id 查日志",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "tracelogkit-loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 63 },
      "id": 10,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": true, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{ "expr": "{project=~\"$project\"} | json | trace_id=\"$trace_id\"", "refId": "A" }],
      "title": "按 trace_id 查日志",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "tracelogkit-loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 75 },
      "id": 11,
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": true, "showCommonLabels": false, "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{ "expr": "{project=~\"$project\"} | json | request_id=\"$request_id\"", "refId": "A" }],
      "title": "按 request_id 查日志",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["tracelogkit", "logs", "incident"],
  "templating": {
    "list": [
      { "name": "project", "label": "project", "type": "query", "datasource": { "type": "loki", "uid": "tracelogkit-loki" }, "query": "label_values(project)", "refresh": 2, "includeAll": false, "multi": true, "current": { "selected": false, "text": "", "value": "" }, "hide": 0 },
      { "name": "service", "label": "service (regex)", "type": "textbox", "query": ".*", "hide": 0, "current": { "selected": false, "text": ".*", "value": ".*" } },
      { "name": "task_id", "label": "task_id", "type": "textbox", "query": "", "hide": 0, "current": { "selected": false, "text": "", "value": "" } },
      { "name": "trace_id", "label": "trace_id", "type": "textbox", "query": "", "hide": 0, "current": { "selected": false, "text": "", "value": "" } },
      { "name": "request_id", "label": "request_id", "type": "textbox", "query": "", "hide": 0, "current": { "selected": false, "text": "", "value": "" } }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Logs",
