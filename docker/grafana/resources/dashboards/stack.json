  "panels": [
    {
      "description": "**目的**：检查 TraceLogKit 可观测栈自身健康（Infra + 采集链路）。\n\n**排障顺序**：\n1) 先看组件是否 UP\n2) 再看 scrape 质量、采集链路（OTel/Tempo/Loki 接收/导出）\n3) 若异常，再进入 Logs / Traces 排查业务问题",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "content": "", "mode": "markdown" },
      "title": "使用说明",
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "description": "Prometheus / OTel Collector / Tempo / Loki 是否可用。",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1 } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 5 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "expr": "max(up{job=\"tracelogkit-prometheus\"})", "legendFormat": "UP", "refId": "A" }],
      "title": "UP - Prometheus",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1 } },
