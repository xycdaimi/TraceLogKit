      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value" },
      "targets": [{ "expr": "max(up{job=\"tracelogkit-tempo\"})", "legendFormat": "UP", "refId": "A" }],
      "title": "UP - Tempo",
      "type": "stat"
