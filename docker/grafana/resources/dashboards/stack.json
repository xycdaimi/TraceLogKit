      "targets": [{ "expr": "max(up{job=\"tracelogkit-otel-collector\"})", "legendFormat": "UP", "refId": "A" }],
      "title": "UP - OTel Collector",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
