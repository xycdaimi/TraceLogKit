      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "max by (job) (scrape_duration_seconds{job=~\"tracelogkit-(prometheus|otel-collector|tempo|loki)\"})", "legendFormat": "{{job}}", "refId": "A" }],
      "title": "Scrape duration (s)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "max by (job) (scrape_samples_scraped{job=~\"tracelogkit-(prometheus|otel-collector|tempo|loki)\"})", "legendFormat": "{{job}}", "refId": "A" }],
      "title": "Scrape samples",
      "type": "timeseries"
