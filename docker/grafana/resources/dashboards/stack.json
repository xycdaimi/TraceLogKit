      "targets": [{ "expr": "prometheus_tsdb_head_series", "legendFormat": "head_series", "refId": "A" }],
      "title": "Prometheus TSDB head series",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
