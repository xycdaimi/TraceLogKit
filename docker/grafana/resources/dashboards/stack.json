    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "expr": "sum(rate(otelcol_receiver_accepted_spans[5m]))", "legendFormat": "accepted", "refId": "A" },
        { "expr": "sum(rate(otelcol_receiver_refused_spans[5m]))", "legendFormat": "refused", "refId": "B" }
      ],
      "title": "OTel Collector - receiver spans/s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "expr": "sum(rate(otelcol_exporter_sent_spans[5m]))", "legendFormat": "sent", "refId": "A" },
        { "expr": "sum(rate(otelcol_exporter_send_failed_spans[5m]))", "legendFormat": "failed", "refId": "B" }
      ],
      "title": "OTel Collector - exporter spans/s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "sum(rate(tempo_distributor_spans_received_total[5m]))", "legendFormat": "tempo_spans/s", "refId": "A" }],
      "title": "Tempo - spans received/s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
