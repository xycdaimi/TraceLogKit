    { "asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true, "tags": [], "targetBlank": false, "title": "Stack", "type": "link", "url": "/d/tracelogkit_stack" },
    { "asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true, "tags": [], "targetBlank": false, "title": "Logs", "type": "link", "url": "/d/tracelogkit_logs" },
    { "asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true, "tags": [], "targetBlank": false, "title": "Traces", "type": "link", "url": "/d/tracelogkit_traces" }
  ],
  "panels": [
    {
      "description": "**目的**：监控业务服务的 RPS、错误率、延迟、流量、CPU、内存。\n\n**数据来源**：Prometheus 抓取的业务 targets（project!~\"tracelogkit-.*\"）。\n\n**指标与维度**：\n- **RPS、P95 延迟**：按 service，使用 `http_requests_total` / `http_request_duration_seconds_bucket`。\n- **项目流量、错误率、CPU、内存**：按 project，使用 `http_server_requests_total`、`process_cpu_seconds_total`、`process_resident_memory_bytes`。\n- 面板禁止使用 job，只用 project。详见《客户端普罗米修斯规范》。",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "content": "", "mode": "markdown" },
      "title": "使用说明",
      "type": "text"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "description": "业务服务 UP 状态（排除 TraceLogKit 基础设施）。",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 1 }, "overrides": [] },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 5 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "up{project!~\"tracelogkit-.*\"}", "instant": true, "refId": "A" }],
      "title": "UP - 业务服务",
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "description": "RPS（按 service，使用 http_requests_total）。",
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 11 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total[5m]))", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "title": "RPS - 按 service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "description": "HTTP 4xx/5xx 错误率（按 project，>5% 触发告警）。",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 11 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "expr": "100 * (sum by (project) (rate(http_server_requests_total{code=~\"[45]..\"}[5m])) / sum by (project) (rate(http_server_requests_total[5m])))", "legendFormat": "{{project}}", "refId": "A" }
      ],
      "title": "错误率 (%) - 按 project",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "description": "P95 延迟（按 service，使用 http_request_duration_seconds_bucket）。",
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 } },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "title": "P95 延迟 (s) - 按 service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "description": "按 project 聚合的请求量（http_server_requests_total）。",
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 } },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 31 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "sum by (project) (rate(http_server_requests_total[5m]))", "legendFormat": "{{project}}", "refId": "A" }],
      "title": "RPS - 按 project",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "description": "目标项目进程 CPU 使用率（process_cpu_seconds_total，依赖业务服务暴露）。",
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 } },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 31 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "100 * sum by (project) (rate(process_cpu_seconds_total{project!~\"tracelogkit-.*\"}[5m]))", "legendFormat": "{{project}}", "refId": "A" }],
      "title": "CPU 使用率 (%) - 按 project",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
      "description": "目标项目进程内存（process_resident_memory_bytes，依赖业务服务暴露）。",
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 } },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 41 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [{ "expr": "sum by (project) (process_resident_memory_bytes{project!~\"tracelogkit-.*\"})", "legendFormat": "{{project}}", "refId": "A" }],
      "title": "内存 (RSS) - 按 project",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["tracelogkit", "business", "metrics"],
  "templating": {
    "list": [
      {
        "name": "project",
        "label": "project",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
        "query": "label_values(http_server_requests_total, project)",
        "refresh": 2,
        "includeAll": false,
        "multi": true,
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0
      },
      {
        "name": "service",
        "label": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "tracelogkit-prometheus" },
        "query": "label_values(http_requests_total, service)",
        "refresh": 2,
        "includeAll": false,
        "multi": true,
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
