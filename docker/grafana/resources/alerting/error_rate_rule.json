{
  "title": "项目错误率过高",
  "ruleGroup": "project_error_rate",
  "folderUID": "tracelogkit",
  "noDataState": "OK",
  "execErrState": "Error",
  "for": "30s",
  "uid": "project_error_rate_5",
  "condition": "C",
  "annotations": {
    "summary": "项目 {{ $labels.project }} HTTP 错误率过高",
    "description": "错误率 {{ printf \"%.2f\" $values.B.Value }}%，超过 5%（5m，持续 30s）。"
  },
  "labels": {
    "severity": "critical"
  },
  "data": [
    {
      "refId": "A",
      "queryType": "",
      "relativeTimeRange": {
        "from": 300,
        "to": 0
      },
      "datasourceUid": "tracelogkit-prometheus",
      "model": {
        "expr": "100 * (sum by (project) (rate(http_server_requests_total{code=~\"[45]..\"}[5m])) / sum by (project) (rate(http_server_requests_total[5m])))",
        "hide": false,
        "intervalMs": 1000,
        "maxDataPoints": 43200,
        "refId": "A"
      }
    },
    {
      "refId": "B",
      "queryType": "",
      "relativeTimeRange": {
        "from": 0,
        "to": 0
      },
      "datasourceUid": "-100",
      "model": {
        "expression": "A",
        "reducer": "last",
        "hide": false,
        "intervalMs": 1000,
        "maxDataPoints": 43200,
        "refId": "B",
        "type": "reduce"
      }
    },
    {
      "refId": "C",
      "queryType": "",
      "relativeTimeRange": {
        "from": 0,
        "to": 0
      },
      "datasourceUid": "-100",
      "model": {
        "expression": "B",
        "conditions": [
          {
            "evaluator": {
              "params": [5],
              "type": "gt"
            }
          }
        ],
        "hide": false,
        "intervalMs": 1000,
        "maxDataPoints": 43200,
        "refId": "C",
        "type": "threshold"
      }
    }
  ]
}
