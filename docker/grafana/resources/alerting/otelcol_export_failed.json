{
  "title": "OTel Collector 导出失败（spans）",
  "ruleGroup": "ingestion",
  "folderUID": "tracelogkit",
  "noDataState": "OK",
  "execErrState": "Error",
  "for": "1m",
  "uid": "otelcol_export_failed_1",
  "condition": "B",
  "annotations": {
    "summary": "Collector exporter {{ $labels.exporter }} 导出失败",
    "description": "失败速率 {{ printf \"%.2f\" $values.B.Value }} spans/s，持续 1m。"
  },
  "labels": { "severity": "critical" },
  "data": [
    {
      "refId": "A",
      "queryType": "",
      "relativeTimeRange": { "from": 300, "to": 0 },
      "datasourceUid": "tracelogkit-prometheus",
      "model": {
        "expr": "sum by (exporter) (rate(otelcol_exporter_send_failed_spans[5m]))",
        "hide": false,
        "intervalMs": 1000,
        "maxDataPoints": 43200,
        "refId": "A"
      }
    },
    {
      "refId": "B",
      "queryType": "",
      "relativeTimeRange": { "from": 0, "to": 0 },
      "datasourceUid": "-100",
      "model": {
        "conditions": [
          {
            "evaluator": { "params": [0], "type": "gt" },
            "operator": { "type": "and" },
            "query": { "params": ["A"] },
            "reducer": { "params": [], "type": "last" },
            "type": "query"
          }
        ],
        "datasource": { "type": "__expr__", "uid": "-100" },
        "hide": false,
        "intervalMs": 1000,
        "maxDataPoints": 43200,
        "refId": "B",
        "type": "classic_conditions"
      }
    }
  ]
}

