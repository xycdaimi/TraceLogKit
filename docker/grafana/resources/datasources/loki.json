{
  "name": "Loki",
  "type": "loki",
  "access": "proxy",
  "url": "http://tracelogkit-loki:3100",
  "uid": "tracelogkit-loki",
  "jsonData": {
    "derivedFields": [
      {
        "name": "trace_id",
        "matcherRegex": "\"trace_id\"\\s*:\\s*\"([0-9a-fA-F]{32})\"",
        "url": "/d/tracelogkit_traces?var-trace_id=${__value.raw}",
        "urlDisplayLabel": "Traces 面板"
      },
      {
        "name": "task_id",
        "matcherRegex": "\"task_id\"\\s*:\\s*\"([^\"]+)\"",
        "url": "/d/tracelogkit_traces?var-task_id=${__value.raw}",
        "urlDisplayLabel": "Traces 面板"
      }
    ]
  }
}
